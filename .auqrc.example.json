{
  "$schema": "https://raw.githubusercontent.com/paulp-o/ask-user-questions-mcp/main/.auqrc.schema.json",

  "// Limits": "Configure question and option limits",
  "maxOptions": 5,
  "maxQuestions": 5,
  "recommendedOptions": 4,
  "recommendedQuestions": 4,

  "// Session": "Session behavior settings",
  "sessionTimeout": 0,
  "retentionPeriod": 604800000,

  "// UI": "User interface settings",
  "language": "auto",
  "theme": "system",
  "autoSelectRecommended": true,

  "// Stale/Orphan Detection": "Configure stale session detection behavior",
  "staleThreshold": 7200000,
  "notifyOnStale": true,
  "staleAction": "warn"
}
